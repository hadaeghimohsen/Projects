@{
    Layout = "_Layout";
    ViewData["Title"] = "تاریخچه نمونه‌های نصب";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="fw-bold mb-0">تاریخچه نمونه‌های نصب</h4>
        <p class="text-muted mt-1 mb-0">لیست تغییرات نمونه‌های نصب نرم‌افزار</p>
    </div>
    <a href="@Url.Action("DASH_BORD_V", "DASH_BORD_CTRL")" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-right me-1"></i>بازگشت
    </a>
</div>

<div class="table-wrap">
    <div class="card">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <input type="text" id="filterUAIN_CODE" class="form-control" placeholder="کد نمونه نصب" onkeypress="if(event.key==='Enter'){loadItems(1)}">
                </div>
                <div class="col-md-4">
                    <input type="text" id="filterCHNG_STAT" class="form-control" placeholder="وضعیت تغییر" onkeypress="if(event.key==='Enter'){loadItems(1)}">
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100" onclick="loadItems(1)">جستجو</button>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="itemsTable">
                <thead>
                    <tr>
                        <th>کد نمونه نصب</th>
                        <th>کد</th>
                        <th>وضعیت تغییر</th>
                        <th>ایجاد کننده</th>
                        <th>تاریخ ایجاد</th>
                    </tr>
                </thead>
                <tbody id="itemsTableBody">
                    <tr>
                        <td colspan="5" class="text-center text-muted">در حال بارگذاری...</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div id="paginationContainer" class="px-3 pb-3 pt-2"></div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var tbody = document.getElementById('itemsTableBody');
            var currentPage = 1;

            function getFilter() {
                return {
                    uainCode: document.getElementById('filterUAIN_CODE').value,
                    chngStat: document.getElementById('filterCHNG_STAT').value
                };
            }

            function loadItems(page) {
                var f = getFilter();
                var q = 'page=' + page
                    + '&uainCode=' + encodeURIComponent(f.uainCode)
                    + '&chngStat=' + encodeURIComponent(f.chngStat);
                fetch('/EXTR_UAIH_CTRL/LIST_UAIH_U?' + q)
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data.rspncode !== '0') {
                            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-danger">خطا در دریافت داده</td></tr>';
                            return;
                        }
                        var items = data.data;
                        currentPage = parseInt(data.page_numb) || 1;
                        var totalCount = parseInt(data.total_count) || 0;
                        var pageSize = parseInt(data.page_size) || 20;
                        var totalPages = Math.ceil(totalCount / pageSize) || 1;
                        if (!items || items.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">موردی یافت نشد</td></tr>';
                            renderPagination(totalPages, totalCount);
                            return;
                        }
                        var html = '';
                        for (var i = 0; i < items.length; i++) {
                            var item = items[i];
                            html += '<tr>' +
                                '<td>' + escapeHtml(item.UAIN_CODE || '') + '</td>' +
                                '<td>' + escapeHtml(item.CODE || '') + '</td>' +
                                '<td>' + escapeHtml(item.CHNG_STAT || '') + '</td>' +
                                '<td>' + escapeHtml(item.CRET_BY || '') + '</td>' +
                                '<td>' + toPersianDate(item.CRET_DATE) + '</td>' +
                                '</tr>';
                        }
                        tbody.innerHTML = html;
                        renderPagination(totalPages, totalCount);
                    })
                    .catch(function () {
                        tbody.innerHTML = '<tr><td colspan="5" class="text-center text-danger">خطا در ارتباط با سرور</td></tr>';
                    });
            }

            function renderPagination(totalPages, totalCount) {
                var container = document.getElementById('paginationContainer');
                if (!container) return;
                var html = '<div class="d-flex justify-content-between align-items-center mt-3">';
                html += '<span class="text-muted small">' + toPersianNumber(totalCount) + ' مورد</span>';
                html += '<ul class="pagination pagination-sm mb-0">';
                html += '<li class="page-item ' + (currentPage <= 1 ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="event.preventDefault(); loadItems(' + (currentPage - 1) + ')">قبلی</a></li>';
                for (var p = 1; p <= totalPages; p++) {
                    html += '<li class="page-item ' + (p === currentPage ? 'active' : '') + '"><a class="page-link" href="#" onclick="event.preventDefault(); loadItems(' + p + ')">' + toPersianNumber(p) + '</a></li>';
                }
                html += '<li class="page-item ' + (currentPage >= totalPages ? 'disabled' : '') + '"><a class="page-link" href="#" onclick="event.preventDefault(); loadItems(' + (currentPage + 1) + ')">بعدی</a></li>';
                html += '</ul></div>';
                container.innerHTML = html;
            }

            function toPersianNumber(num) {
                return num.toString().replace(/\d/g, function (d) { return '\u0660\u0661\u0662\u0663\u0664\u0665\u0666\u0667\u0668\u0669'[d]; });
            }

            function toPersianDate(dateStr) {
                if (!dateStr) return '---';
                var d = new Date(dateStr.replace(' ', 'T'));
                if (isNaN(d.getTime())) return '---';
                return d.toLocaleDateString('fa-IR', { year: 'numeric', month: '2-digit', day: '2-digit' }) + ' \u200e' + d.toLocaleTimeString('fa-IR', { hour: '2-digit', minute: '2-digit' });
            }

            function escapeHtml(text) {
                if (typeof text !== 'string') return text;
                var div = document.createElement('div');
                div.appendChild(document.createTextNode(text));
                return div.innerHTML;
            }

            window.loadItems = loadItems;
            loadItems(1);
        })();
    </script>
}
