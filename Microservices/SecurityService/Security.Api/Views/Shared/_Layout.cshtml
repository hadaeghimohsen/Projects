        .toast-container { position: fixed; z-index: 9999; pointer-events: none; }
        .toast-container.tc-top-left { top: 70px; left: 20px; }
        .toast-container.tc-bottom-right { bottom: 20px; right: 20px; }
        .toast-item {
            pointer-events: auto; padding: 12px 20px; margin-bottom: 8px; border-radius: 8px;
            font-size: 14px; box-shadow: 0 4px 14px rgba(0,0,0,0.12);
            opacity: 0; transform: translateY(-10px);
            transition: opacity 0.3s, transform 0.3s; max-width: 380px; min-width: 250px;
        }
        .toast-item.show { opacity: 1; transform: translateY(0); }
        .toast-item.toast-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .toast-item.toast-error { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
