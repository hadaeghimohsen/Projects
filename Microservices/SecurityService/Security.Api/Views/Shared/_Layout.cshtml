    <script>
        window.showToast = function (msg, type) {
            var container = type === 'success' ? document.getElementById('toastSuccess') : document.getElementById('toastError');
            var el = document.createElement('div');
            el.className = 'toast-item toast-' + type;
            el.textContent = msg;
            container.appendChild(el);
            requestAnimationFrame(function () { el.classList.add('show'); });
            var dur = type === 'success' ? 3000 : 5000;
            setTimeout(function () { el.classList.remove('show'); setTimeout(function () { el.remove(); }, 300); }, dur);
        };
    </script>

