<!DOCTYPE html>
<html lang="fa" class="light-style customizer-hide" dir="rtl" data-theme="theme-default" data-assets-path="@Url.Content("~/frest-assets/")" data-template="vertical-menu-template">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0">
    <title>@ViewData["Title"] - سامانه مدیریت</title>
    <meta name="description" content="">
    <link rel="icon" type="image/x-icon" href="~/frest-assets/img/favicon/favicon.ico">
    <link rel="stylesheet" href="~/frest-assets/vendor/fonts/boxicons.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/fonts/fontawesome.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/fonts/flag-icons.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/css/rtl/core.css" class="template-customizer-core-css">
    <link rel="stylesheet" href="~/frest-assets/vendor/css/rtl/theme-default.css" class="template-customizer-theme-css">
    <link rel="stylesheet" href="~/frest-assets/css/demo.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/css/rtl/rtl.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/libs/typeahead-js/typeahead.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/libs/formvalidation/dist/css/formValidation.min.css">
    <link rel="stylesheet" href="~/frest-assets/vendor/css/pages/page-auth.css">
    <script src="~/frest-assets/vendor/js/helpers.js"></script>
    <script src="~/frest-assets/vendor/js/template-customizer.js"></script>
    <script src="~/frest-assets/js/config.js"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @RenderBody()
    <script src="~/frest-assets/vendor/libs/jquery/jquery.js"></script>
    <script src="~/frest-assets/vendor/libs/popper/popper.js"></script>
    <script src="~/frest-assets/vendor/js/bootstrap.js"></script>
    <script src="~/frest-assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
    <script src="~/frest-assets/vendor/libs/hammer/hammer.js"></script>
    <script src="~/frest-assets/vendor/libs/i18n/i18n.js"></script>
    <script src="~/frest-assets/vendor/libs/typeahead-js/typeahead.js"></script>
    <script src="~/frest-assets/vendor/js/menu.js"></script>
    <script src="~/frest-assets/vendor/libs/formvalidation/dist/js/FormValidation.min.js"></script>
    <script src="~/frest-assets/vendor/libs/formvalidation/dist/js/plugins/Bootstrap5.min.js"></script>
    <script src="~/frest-assets/vendor/libs/formvalidation/dist/js/plugins/AutoFocus.min.js"></script>
    <script src="~/frest-assets/js/main.js"></script>
    <script src="~/frest-assets/js/pages-auth.js"></script>
    @await Html.PartialAsync("_LoadingOverlay")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
