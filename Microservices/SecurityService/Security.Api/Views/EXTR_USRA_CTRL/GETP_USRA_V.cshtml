@{
    Layout = "_Layout";
    ViewData["Title"] = "ویرایش کاربر";
    var userName = ViewData["EditUserName"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="fw-bold mb-0">ویرایش کاربر</h4>
        <p class="text-muted mt-1 mb-0">مشاهده و ویرایش اطلاعات کاربر</p>
    </div>
    <a href="@Url.Action("LIST_USRA_V", "EXTR_USRA_CTRL")" class="btn btn-outline-secondary">
        <i class="bx bx-arrow-right me-1"></i>بازگشت به لیست
    </a>
</div>

<div class="card">
    <div class="card-body text-center pt-4 pb-3">
        <div class="profile-avatar-wrap">
            <img src="~/frest-assets/img/avatars/1.png" alt="avatar" id="profileAvatar">
            <div class="profile-avatar-overlay">
                <i class="bx bx-camera"></i>
            </div>
            <input type="file" id="avatarInput" accept="image/*" style="display:none">
        </div>
        <h5 class="mt-3 mb-0" id="profileName">---</h5>
        <small class="text-muted" id="profileUsername">@userName</small>
    </div>
    <hr class="m-0">
    <div class="card-body">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">نام کاربری</label>
                <input type="text" class="form-control" id="edtUserName" readonly>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">نام و نام خانوادگی</label>
                <input type="text" class="form-control" id="edtUserDesc">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">تلفن همراه</label>
                <input type="text" class="form-control" id="edtPhone">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">ایمیل</label>
                <input type="email" class="form-control" id="edtEmail">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">وضعیت</label>
                <select class="form-select" id="edtStatus"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">وضعیت ایمیل</label>
                <select class="form-select" id="edtEmailVerf"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">وضعیت TOTP</label>
                <select class="form-select" id="edtTotp"></select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">اندازه صفحه</label>
                <input type="number" class="form-control" id="edtPageSize" min="5" max="200">
            </div>
        </div>
        <div class="text-center mt-3">
            <button class="btn btn-primary px-5" onclick="saveUser()">ذخیره تغییرات</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var editUser = '@(ViewData["EditUserName"] ?? "")';

            var statusOpts = { '002': 'فعال', '001': 'غیرفعال' };
            var yesNoOpts = { 'YES': 'بله', 'NO': 'خیر' };

            function populateSelect(id, opts, selected) {
                var sel = document.getElementById(id);
                if (!sel) return;
                var html = '<option value="">---</option>';
                for (var k in opts) {
                    html += '<option value="' + k + '"' + (k === selected ? ' selected' : '') + '>' + opts[k] + '</option>';
                }
                sel.innerHTML = html;
            }

            function loadProfile() {
                if (!editUser) return;
                showLoading();
                var payload = JSON.stringify({
                    _username: editUser,
                    operation: { type: '004', desc: 'Get user profile' }
                });
                fetch('/EXTR_USRA_CTRL/GETP_USRA_U', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: payload
                })
                .then(function (r) { return r.json(); })
                .then(function (res) {
                    hideLoading();
                    if (!res.success) { alert('خطا در دریافت اطلاعات'); return; }
                    var u = res.data;
                    document.getElementById('profileName').textContent = u.USER_APP_DESC || u.USER_APP_NAME;
                    document.getElementById('profileUsername').textContent = u.USER_APP_NAME;
                    document.getElementById('edtUserName').value = u.USER_APP_NAME || '';
                    document.getElementById('edtUserDesc').value = u.USER_APP_DESC || '';
                    document.getElementById('edtPhone').value = u.PHON_NUMB || '';
                    document.getElementById('edtEmail').value = u.EMAL_ADRS || '';
                    document.getElementById('edtPageSize').value = u.VIEW_PAGE_SIZE || '';
                    populateSelect('edtStatus', statusOpts, u.STAT);
                    populateSelect('edtEmailVerf', yesNoOpts, u.EMAL_VERF_STAT);
                    populateSelect('edtTotp', yesNoOpts, u.TOTP_STAT);
                })
                .catch(function () { hideLoading(); alert('خطا در ارتباط با سرور'); });
            }

            window.saveUser = function () {
                alert('ذخیره اطلاعات کاربر: ' + editUser + ' (به زودی پیاده‌سازی می‌شود)');
            };

            document.getElementById('profileAvatar')?.addEventListener('click', function () {
                document.getElementById('avatarInput').click();
            });
            document.getElementById('avatarInput')?.addEventListener('change', function (e) {
                if (e.target.files && e.target.files[0]) {
                    var img = document.getElementById('profileAvatar');
                    img.src = URL.createObjectURL(e.target.files[0]);
                }
            });

            loadProfile();
        })();
    </script>
}
