@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "ورود به سیستم";
}

<style>
    .auth-bg-animated {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #5A8DEE 0%, #699AF9 30%, #A8D0FF 70%, #D5E5FF 100%);
        background-size: 400% 400%;
        animation: gradientShift 12s ease infinite;
    }
    @@keyframes gradientShift {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .auth-bg-animated .shape {
        position: absolute;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        animation: floatUp 20s ease-in-out infinite;
    }
    .auth-bg-animated .shape:nth-child(1) {
        width: 300px; height: 300px; top: -50px; left: -80px;
        animation-duration: 18s; animation-delay: 0s;
    }
    .auth-bg-animated .shape:nth-child(2) {
        width: 200px; height: 200px; bottom: 10%; right: 5%;
        animation-duration: 22s; animation-delay: -4s;
    }
    .auth-bg-animated .shape:nth-child(3) {
        width: 150px; height: 150px; top: 40%; left: 60%;
        animation-duration: 16s; animation-delay: -8s;
    }
    .auth-bg-animated .shape:nth-child(4) {
        width: 80px; height: 80px; top: 20%; right: 30%;
        animation-duration: 14s; animation-delay: -2s;
    }
    .auth-bg-animated .shape:nth-child(5) {
        width: 400px; height: 400px; bottom: -100px; left: -100px;
        animation-duration: 25s; animation-delay: -6s;
    }
    @@keyframes floatUp {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-30px) scale(1.05); }
    }
    .auth-bg-animated .welcome-content {
        position: relative;
        z-index: 1;
    }
    .owl-mascot {
        flex-shrink: 0;
        animation: owlFloat 3s ease-in-out infinite;
    }
    @@keyframes owlFloat {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
    }
    .owl-body {
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .owl-body.look-down {
        transform: rotate(3deg) translateY(3px);
    }
    .owl-eyes {
        transform-origin: 50% 49%;
        transition: transform 0.1s ease;
    }
    .owl-eyes.blink {
        transform: scaleY(0.08);
    }
    .owl-eyes.slow-blink {
        transform: scaleY(0.08);
        transition: transform 0.25s ease;
    }
    .owl-wing {
        transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .owl-wing-l.covering {
        transform: translate(21px, -16px);
    }
    .owl-wing-r.covering {
        transform: translate(-21px, -16px);
    }
    .owl-wing-l.peek {
        transform: translate(13px, -16px);
    }
    .owl-body.peeking {
        transform: rotate(-2deg) translateY(2px);
    }
</style>

<div class="authentication-wrapper authentication-cover">
    <div class="authentication-inner row m-0">
        <div class="d-none d-lg-flex col-lg-7 col-xl-8 align-items-center auth-bg-animated">
            <div class="shape"></div>
            <div class="shape"></div>
            <div class="shape"></div>
            <div class="shape"></div>
            <div class="shape"></div>
            <div class="welcome-content flex-row text-center mx-auto">
                <div class="mx-auto mb-4">
                    <h3 class="text-white fw-bold mb-3">به سامانه مدیریت خوش آمدید</h3>
                    <p class="text-white opacity-75 fs-5 mb-0">
                        سامانه جامع مدیریت کاربران و احراز هویت<br>
                        امنیت بالا با تایید دو مرحله‌ای
                    </p>
                </div>
                <div class="mt-4">
                    <div class="d-flex justify-content-center gap-4">
                        <div class="text-center px-3">
                            <span class="d-block text-white fw-bold fs-4">+۵۰۰</span>
                            <small class="text-white opacity-75">کاربر فعال</small>
                        </div>
                        <div class="text-center px-3 border-start border-white border-opacity-25">
                            <span class="d-block text-white fw-bold fs-4">+۲۰</span>
                            <small class="text-white opacity-75">ماژول فعال</small>
                        </div>
                        <div class="text-center px-3 border-start border-white border-opacity-25">
                            <span class="d-block text-white fw-bold fs-4">۹۹٪</span>
                            <small class="text-white opacity-75">uptime</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex col-12 col-lg-5 col-xl-4 align-items-center authentication-bg p-sm-5 p-4">
            <div class="w-px-400 mx-auto">
                <div class="app-brand mb-4">
                    <a href="~/" class="app-brand-link gap-2 mb-2">
                        <span class="app-brand-logo demo">
                            <svg width="26" height="26" viewbox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="5.5" y="5.5" width="15" height="15" rx="3" fill="url(#lg-grad)" />
                                <circle cx="13" cy="13" r="4" fill="#fff" />
                                <defs>
                                    <linearGradient id="lg-grad" x1="0" y1="0" x2="26" y2="26">
                                        <stop stop-color="#5A8DEE" />
                                        <stop offset="1" stop-color="#699AF9" />
                                    </linearGradient>
                                </defs>
                            </svg>
                        </span>
                        <span class="app-brand-text demo h3 mb-0 fw-bold">سامانه مدیریت</span>
                    </a>
                </div>
                <div class="d-flex align-items-center mb-4 gap-2">
                    <div class="flex-grow-1">
                        <h4 class="mb-1 secondary-font">خوش آمدید!</h4>
                        <p class="mb-0 text-muted">لطفا وارد حساب خود شده و ماجراجویی را شروع کنید</p>
                    </div>
                    <div class="owl-mascot" id="owlMascot">
                        <svg viewBox="0 0 100 115" width="72" height="83" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g class="owl-body">
                                <ellipse cx="50" cy="70" rx="36" ry="34" fill="#f0f5ff"/>
                                <ellipse cx="50" cy="74" rx="26" ry="22" fill="#e5edff"/>
                                <path d="M16 40 L8 12 L28 32 Z" fill="#5A8DEE"/>
                                <path d="M84 40 L92 12 L72 32 Z" fill="#5A8DEE"/>
                                <g class="owl-eyes">
                                    <circle cx="34" cy="56" r="13" fill="#fff" stroke="#5A8DEE" stroke-width="1.2"/>
                                    <circle cx="34" cy="56" r="8" fill="#5A8DEE"/>
                                    <circle class="owl-pupil" data-base="34,56" cx="34" cy="56" r="4.5" fill="#2d3436"/>
                                    <circle cx="31" cy="53" r="2" fill="#fff" opacity=".9"/>
                                    <circle cx="66" cy="56" r="13" fill="#fff" stroke="#5A8DEE" stroke-width="1.2"/>
                                    <circle cx="66" cy="56" r="8" fill="#5A8DEE"/>
                                    <circle class="owl-pupil" data-base="66,56" cx="66" cy="56" r="4.5" fill="#2d3436"/>
                                    <circle cx="63" cy="53" r="2" fill="#fff" opacity=".9"/>
                                </g>
                                <path d="M50 66 L46 74 L54 74 Z" fill="#f5a623"/>
                                <path d="M30 104 L30 110 M26 110 L34 110" stroke="#5A8DEE" stroke-width="2.2" stroke-linecap="round"/>
                                <path d="M70 104 L70 110 M66 110 L74 110" stroke="#5A8DEE" stroke-width="2.2" stroke-linecap="round"/>
                            </g>
                            <ellipse class="owl-wing owl-wing-l" cx="14" cy="72" rx="10" ry="14" fill="#dce6fa"/>
                            <ellipse class="owl-wing owl-wing-r" cx="86" cy="72" rx="10" ry="14" fill="#dce6fa"/>
                        </svg>
                    </div>
                </div>

                <form id="loginForm" class="mb-3" method="post" action="javascript:void(0);">
                    <div id="stepCredentials">
                        <div class="mb-3">
                            <label for="username" class="form-label">نام کاربری</label>
                            <input type="text" class="form-control" id="username" name="username" autofocus dir="ltr" inputmode="latin" autocapitalize="off" onkeypress="return event.keyCode >= 65 && event.keyCode <= 90 || event.keyCode >= 97 && event.keyCode <= 122 || event.keyCode >= 48 && event.keyCode <= 57 || event.keyCode === 8 || event.keyCode === 46 || event.keyCode === 45 || event.keyCode === 95">
                        </div>
                        <div class="mb-3 form-password-toggle">
                            <div class="d-flex justify-content-between">
                                <label class="form-label" for="password">رمز عبور</label>
                                <a href="javascript:void(0);">
                                    <small class="text-muted">رمز عبور را فراموش کردید؟</small>
                                </a>
                            </div>
                            <div class="input-group input-group-merge">
                                <input type="password" id="password" class="form-control" name="password" aria-describedby="password" dir="ltr" inputmode="latin" autocapitalize="off" onkeypress="return event.keyCode >= 65 && event.keyCode <= 90 || event.keyCode >= 97 && event.keyCode <= 122 || event.keyCode >= 48 && event.keyCode <= 57 || event.keyCode >= 33 && event.keyCode <= 64 || event.keyCode === 8 || event.keyCode === 32">
                                <span class="input-group-text cursor-pointer" id="toggle-password"><i class="bx bx-hide"></i></span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="remember-me">
                                <label class="form-check-label" for="remember-me">من را به خاطر بسپار <small class="text-muted">(۷ روز)</small></label>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary d-grid w-100 waves-effect waves-light">ورود</button>
                    </div>

                    <div id="stepTotp" class="d-none">
                        <div class="text-center mb-3">
                            <i class="bx bx-shield-quarter" style="font-size:3rem;color:#5A8DEE;"></i>
                            <h5 class="mt-2 mb-1">تأیید دو مرحله‌ای</h5>
                            <p class="text-muted small mb-0">کد ۶ رقمی اپلیکیشن authenticator را وارد کنید</p>
                        </div>
                        <div class="mb-3">
                            <label for="totpCode" class="form-label">کد تأیید</label>
                            <input type="text" id="totpCode" maxlength="6" inputmode="numeric" pattern="[0-9]{6}"
                                   class="form-control form-control-lg text-center fw-bold"
                                   placeholder="------" dir="ltr" autocomplete="one-time-code"
                                   style="letter-spacing:0.5rem;font-size:1.5rem;" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="button" id="btnTotpBack" class="btn btn-label-secondary flex-shrink-0">
                                <i class="bx bx-arrow-back"></i>
                            </button>
                            <button type="submit" id="btnTotpSubmit" class="btn btn-primary flex-grow-1 waves-effect waves-light">تأیید</button>
                        </div>
                    </div>

                    <div id="message" class="mt-3"></div>
                </form>

                <div class="text-center mt-1">
                    <p class="text-muted mb-0">
                        حساب کاربری ندارید؟
                        <a href="@Url.Action("RGTR_USRA_V", "EXTR_USRA_CTRL")" class="fw-bold">ثبت نام کنید</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        (function () {
            var username = document.getElementById('username');
            var password = document.getElementById('password');
            var pupils = document.querySelectorAll('.owl-pupil');
            var eyes = document.querySelector('.owl-eyes');
            var body = document.querySelector('.owl-body');
            var wingL = document.querySelector('.owl-wing-l');
            var wingR = document.querySelector('.owl-wing-r');
            var blinkTimer;
            var focusing = false;

            function setPupils(dx, dy) {
                var t = 'translate(' + dx.toFixed(1) + ', ' + dy.toFixed(1) + ')';
                pupils.forEach(function (p) { p.setAttribute('transform', t); });
            }

            function movePupils(x, y) {
                if (!focusing) return;
                var rect = username.getBoundingClientRect();
                var cx = rect.left + rect.width / 2;
                var cy = rect.top + rect.height / 2;
                var dx = (x - cx) / (rect.width / 2);
                var dy = (y - cy) / (rect.height / 2);
                dx = Math.max(-1, Math.min(1, dx)) * 4;
                dy = Math.max(-1, Math.min(1, dy)) * 3;
                setPupils(dx, dy);
            }

            function resetPupils() {
                setPupils(0, 0);
            }

            function doBlink(slow) {
                eyes.classList.remove('blink', 'slow-blink');
                void eyes.offsetWidth;
                eyes.classList.add(slow ? 'slow-blink' : 'blink');
                setTimeout(function () { eyes.classList.remove('blink', 'slow-blink'); }, slow ? 300 : 150);
            }

            function scheduleBlink() {
                clearTimeout(blinkTimer);
                blinkTimer = setTimeout(function () { doBlink(); scheduleBlink(); }, 2500 + Math.random() * 4000);
            }

            username.addEventListener('focus', function () {
                focusing = true;
                body.classList.add('look-down');
                setPupils(0, 5);
                setTimeout(function () { doBlink(true); }, 200);
                scheduleBlink();
            });
            username.addEventListener('blur', function () {
                focusing = false;
                body.classList.remove('look-down');
                resetPupils();
                clearTimeout(blinkTimer);
            });
            username.addEventListener('mousemove', function (e) { movePupils(e.clientX, e.clientY); });

            password.addEventListener('focus', function () {
                wingL.classList.add('covering');
                wingR.classList.add('covering');
                body.classList.remove('peeking');
                wingL.classList.remove('peek');
            });
            password.addEventListener('blur', function () {
                wingL.classList.remove('covering', 'peek');
                wingR.classList.remove('covering');
                body.classList.remove('peeking');
            });

            var toggleBtn = document.getElementById('toggle-password');
            if (toggleBtn) {
                toggleBtn.addEventListener('click', function () {
                    setTimeout(function () {
                        if (password.type === 'text') {
                            wingL.classList.remove('covering');
                            wingL.classList.add('peek');
                            body.classList.add('peeking');
                            doBlink(true);
                        } else {
                            wingL.classList.remove('peek');
                            wingL.classList.add('covering');
                            body.classList.remove('peeking');
                        }
                    }, 50);
                });
            }

            setTimeout(function () { setTimeout(scheduleBlink, 2000); }, 1000);
        })();
    </script>
    <script>
        (function () {
            var loginForm = document.getElementById('loginForm');
            var stepCredentials = document.getElementById('stepCredentials');
            var stepTotp = document.getElementById('stepTotp');
            var usernameInput = document.getElementById('username');
            var passwordInput = document.getElementById('password');
            var totpCodeInput = document.getElementById('totpCode');
            var btnTotpBack = document.getElementById('btnTotpBack');
            var btnTotpSubmit = document.getElementById('btnTotpSubmit');
            var messageDiv = document.getElementById('message');
            var rememberCheck = document.getElementById('remember-me');
            var loginBtn = loginForm.querySelector('#stepCredentials button[type="submit"]');

            var currentTotpToken = '';

            if (localStorage.getItem('rememberedUser')) {
                usernameInput.value = localStorage.getItem('rememberedUser');
                rememberCheck.checked = true;
            }

            function showMessage(text, type) {
                messageDiv.className = 'alert alert-' + (type || 'danger');
                messageDiv.textContent = text;
            }

            function showStep(name) {
                if (name === 'totp') {
                    stepCredentials.classList.add('d-none');
                    stepTotp.classList.remove('d-none');
                    setTimeout(function () { totpCodeInput.focus(); }, 50);
                } else {
                    stepTotp.classList.add('d-none');
                    stepCredentials.classList.remove('d-none');
                    messageDiv.textContent = '';
                    messageDiv.className = '';
                    setTimeout(function () { passwordInput.focus(); }, 50);
                }
            }

            async function tryLogin(payload, maxRetries) {
                for (var attempt = 1; attempt <= maxRetries; attempt++) {
                    try {
                        var response = await fetch('/EXTR_USRA_CTRL/LGIN_USRA_U', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        return await response.json();
                    } catch (err) {
                        if (attempt === maxRetries) throw err;
                        await new Promise(function (r) { setTimeout(r, 1000); });
                    }
                }
            }

            async function tryTotp(payload, maxRetries) {
                console.log('tryTotp sending payload:', payload);
                for (var attempt = 1; attempt <= maxRetries; attempt++) {
                    try {
                        var response = await fetch('/EXTR_USRA_CTRL/LGIN_TOTP_U', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        console.log('tryTotp response status:', response.status);
                        return await response.json();
                    } catch (err) {
                        console.error('tryTotp error:', err);
                        if (attempt === maxRetries) throw err;
                        await new Promise(function (r) { setTimeout(r, 1000); });
                    }
                }
            }

            async function submitCredentials() {
                var username = usernameInput.value.trim().toUpperCase();
                var password = passwordInput.value;
                if (!username || !password) {
                    showMessage('لطفا نام کاربری و رمز عبور را وارد کنید', 'danger');
                    return;
                }
                if (rememberCheck.checked) {
                    localStorage.setItem('rememberedUser', username);
                } else {
                    localStorage.removeItem('rememberedUser');
                }
                var payload = JSON.stringify({
                    lgintype: '001',
                    USER_APP_NAME: username,
                    PASS_WORD: password,
                    REMEMBER_ME: rememberCheck.checked ? '1' : '0'
                });
                loginBtn.disabled = true;
                showLoading('در حال بررسی اطلاعات ورود...');
                try {
                    var data = await tryLogin(payload, 3);
                    console.log('LGIN_USRA_U response:', data);
                    if (data.requiresTotp) {
                        currentTotpToken = data.totpToken;
                        console.log('Set currentTotpToken:', currentTotpToken);
                        hideLoading();
                        messageDiv.textContent = '';
                        showStep('totp');
                        loginBtn.disabled = false;
                    } else if (data.success) {
                        localStorage.setItem('token', data.token);
                        showMessage('در حال انتقال به داشبورد...', 'success');
                        window.location.href = '@Url.Action("DASH_BORD_V", "DASH_BORD_CTRL")';
                    } else {
                        hideLoading();
                        loginBtn.disabled = false;
                        showMessage(data.rspndesc || data.oracleErrorMessage || 'خطا در ورود', 'danger');
                    }
                } catch {
                    hideLoading();
                    loginBtn.disabled = false;
                    showMessage('سرور در دسترس نیست. پس از بررسی اتصال خود، مجددا تلاش کنید.', 'danger');
                }
            }

            async function submitTotp() {
                var code = totpCodeInput.value.trim();
                if (!/^\d{6}$/.test(code)) {
                    showMessage('کد باید ۶ رقم باشد', 'danger');
                    return;
                }
                console.log('submitTotp - currentTotpToken:', currentTotpToken, 'code:', code);
                if (!currentTotpToken) {
                    showMessage('نشست منقضی شده. مجدداً نام کاربری/رمز را وارد کنید.', 'danger');
                    showStep('credentials');
                    return;
                }
                btnTotpSubmit.disabled = true;
                showLoading('در حال تأیید کد...');
                try {
                    var data = await tryTotp(JSON.stringify({ totp_token: currentTotpToken, code: code }), 3);
                    if (data.success) {
                        localStorage.setItem('token', data.token);
                        showMessage('در حال انتقال به داشبورد...', 'success');
                        window.location.href = '@Url.Action("DASH_BORD_V", "DASH_BORD_CTRL")';
                    } else {
                        hideLoading();
                        btnTotpSubmit.disabled = false;
                        showMessage(data.rspndesc || 'کد تأیید نامعتبر است', 'danger');
                        totpCodeInput.value = '';
                        totpCodeInput.focus();
                    }
                } catch {
                    hideLoading();
                    btnTotpSubmit.disabled = false;
                    showMessage('سرور در دسترس نیست', 'danger');
                }
            }

            loginForm.addEventListener('submit', function (e) {
                e.preventDefault();
                if (!stepCredentials.classList.contains('d-none')) {
                    submitCredentials();
                } else if (!stepTotp.classList.contains('d-none')) {
                    submitTotp();
                }
            });

            btnTotpBack.addEventListener('click', function () {
                currentTotpToken = '';
                totpCodeInput.value = '';
                btnTotpSubmit.disabled = false;
                showStep('credentials');
            });

            totpCodeInput.addEventListener('input', function () {
                totpCodeInput.value = totpCodeInput.value.replace(/\D/g, '').substring(0, 6);
                if (totpCodeInput.value.length === 6) {
                    submitTotp();
                }
            });
        })();
    </script>
}
